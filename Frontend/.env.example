# Frontend Configuration
REACT_APP_API_URL=http://localhost:5000

# ============================================================
# 🎉 100% FREE MAPS - Using Leaflet + OpenStreetMap
# ============================================================

# OpenStreetMap Tiles (COMPLETELY FREE)
REACT_APP_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
REACT_APP_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors

# Map Settings (Using Free Services)
REACT_APP_DEFAULT_MAP_CENTER_LAT=17.4399
REACT_APP_DEFAULT_MAP_CENTER_LNG=78.4983
REACT_APP_DEFAULT_MAP_ZOOM=13

# ============================================================
# OPTIONAL: Paid Map Services (Not required)
# Only add these if you want to use premium mapping features
# ============================================================

# Mapbox (Optional, free tier: $0, premium: $0-100+/month)
# REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# Google Maps (Optional, costs $200-500/month)
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App Settings
REACT_APP_DEFAULT_REFRESH_INTERVAL=30

