# Flask Configuration
DEBUG=True
FLASK_ENV=development

# Database Configuration
DATABASE_URL=sqlite:///database/traffic.db

# Redis Cache Configuration (Optional but recommended)
REDIS_URL=redis://localhost:6379/0
CACHE_TIMEOUT=300

# ============================================================
# 🎉 100% FREE APIS - NO COSTS!
# ============================================================

# Geocoding: OpenStreetMap Nominatim (COMPLETELY FREE)
NOMINATIM_USER_AGENT=traffic-detection-app

# Weather: Open-Meteo (COMPLETELY FREE, NO API KEY NEEDED!)
# This is automatic - no configuration needed!

# Routing: OSRM - Open Source Routing Machine (FREE)
OSRM_URL=http://router.project-osrm.org

# Incidents: OpenStreetMap Overpass API (COMPLETELY FREE)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ============================================================
# OPTIONAL: Paid API Keys (Not required for free tier)
# Only add these if you want to use paid services later
# ============================================================

# TomTom Traffic API (Optional, costs $100-300/month)
# TOMTOM_API_KEY=your_tomtom_api_key_here

# HERE Traffic API (Optional, costs $100-300/month)
# HERE_API_KEY=your_here_api_key_here

# Google Maps API (Optional, costs $200-500/month)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox API (Optional, costs $0-100+/month, free tier available)
# MAPBOX_API_KEY=your_mapbox_api_key_here

# ============================================================

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Real-time Updates
WEBSOCKET_ENABLED=true
UPDATE_INTERVAL=30

# Audio Processing (Optional)
AUDIO_ENABLED=false
